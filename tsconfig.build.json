{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "trabecula/*": ["./trabecula/*"]
    },
    "declaration": true,
    "emitDeclarationOnly": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "stripInternal": true,
    "target": "ES2020",
    "types": ["node"]
  },
  "extends": "./tsconfig.base.json",
  "include": ["./trabecula"]
}
