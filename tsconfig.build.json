{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "trabecula/*": ["./trabecula/*"]
    },
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "trabecula",
    "stripInternal": true,
    "target": "ES2020"
  },
  "extends": "./tsconfig.base.json",
  "include": ["./trabecula"]
}
